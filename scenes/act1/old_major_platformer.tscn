[node name="ActIntro" parent="." instance=ExtResource("12_intro")]
act_label_text = "ACT 1 — CHAPTER 1"
title_text = "OLD MAJOR'S DREAM"
protagonist_text = "You are OLD MAJOR — the prize Middle White boar."
story_text = "Late one night, after Mr. Jones has stumbled to bed, the animals of Manor Farm creep into the great barn. Old Major has called them together to share a dream — a vision of an England without humans, where every beast is free."
goal_text = "Make your way across the farmyard and reach the barn door on the right to deliver your speech."
controls = Array[String](["Move: A / D  or  ← →", "Jump: Space / Enter  or  W / ↑", "Lantern: E (after picking it up)"])

