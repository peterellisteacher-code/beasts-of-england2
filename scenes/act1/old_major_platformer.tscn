[node name="ActIntro" parent="." instance=ExtResource("57")]
act_label_text = "ACT 1 — CHAPTER 1"
title_text = "OLD MAJOR'S DREAM"
protagonist_text = "You are OLD MAJOR — the prize boar, wise and old."
story_text = "Mr. Jones has drunk himself to sleep, and the light in the farmhouse has gone out at last. Word has passed from stall to coop: old Major has had a strange dream, and will tell it tonight in the big barn. But not every animal has crept in yet — and Moses, the tame raven, is Jones's spy. Move from shadow to shadow, wake the animals who still sleep, and bring them to the barn unseen."
goal_text = "Wake all four sleeping animals and reach the big barn — without being caught by Moses or the light."
controls = ["Move:  A / D  or  arrow keys", "Wake an animal / pick up:  E", "Hide:  stand in shadow or behind hay", "Show or hide controls:  H"]

[connection signal="body_entered" from="World/BarnDoor" to="." method="on_barn_reached"]
