[node name="Debrief" type="RichTextLabel" parent="."]
offset_left = 100.0
offset_top = 180.0
offset_right = 1180.0
offset_bottom = 560.0
bbcode_enabled = true
theme_override_font_sizes/normal_font_size = 15
text = "[center]You have played through the corruption of Animalism.[/center]

[center][color=#b0995a]Reflect:[/color][/center]

[ul]
[color=#c8b87a]Act 1: Old Major's dream[/color] — what promise does it hold for the animals?
[color=#c8b87a]Act 2: The Revolution[/color] — was it inevitable, or could things have gone differently?
[color=#c8b87a]Act 3: The Battle[/color] — what does Boxer's loyalty cost him in the end?
[color=#c8b87a]Act 4: The expulsion[/color] — could Snowball have won? Could anyone have stopped Napoleon?
[/ul]

[center][color=#8b1a1a]'All animals are equal, but some animals are more equal than others.'[/color][/center]

[center]— George Orwell, [i]Animal Farm[/i] (1945)[/center]"

