[node name="ActIntro" parent="." instance=ExtResource("7_intro")]
act_label_text = "ACT 4 — CHAPTER 5"
title_text = "SNOWBALL'S EXPULSION"
protagonist_text = "You are SNOWBALL — visionary, planner, builder of the windmill."
story_text = "At every meeting Napoleon has set himself against you. Now he has unleashed nine fierce dogs, raised in secret. They mean to chase you off the farm — and Squealer's lies are turning the others against you too."
goal_text = "Survive as long as you can. The grid shrinks every three rounds — there is no winning move, only how long you last."
controls = Array[String](["Click a highlighted GREEN tile to move Snowball", "Then choose Battle Cry, Windmill Plans, or Wait", "Battle Cry: push a nearby dog away", "Windmill Plans: gain defence this round", "Wait: skip your action"])
