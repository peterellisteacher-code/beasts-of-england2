[node name="Heading" type="Label" parent="UiLayer/BriefingOverlay/BriefingCard/MarginContainer/VBox"]
layout_mode = 2
text = "Napoleon — The Interrogation"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.42, 0.24, 0.098, 1)

[node name="Para1" type="Label" parent="UiLayer/BriefingOverlay/BriefingCard/MarginContainer/VBox"]
layout_mode = 2
text = "You have come to Animal Farm to question Napoleon. He will not tell you the truth. He hides what the pigs have done to the other animals. But the truth is in the novel, and you have read it."
autowrap_mode = 3
theme_override_font_sizes/font_size = 15
theme_override_colors/font_color = Color(0.165, 0.102, 0.031, 1)

[node name="Para2" type="Label" parent="UiLayer/BriefingOverlay/BriefingCard/MarginContainer/VBox"]
layout_mode = 2
text = "Catch him in his lies. Name the specific words, the exact change, the real evidence — and Napoleon will falter. Every lie you expose is counted."
autowrap_mode = 3
theme_override_font_sizes/font_size = 15
theme_override_colors/font_color = Color(0.165, 0.102, 0.031, 1)

[node name="Para3" type="Label" parent="UiLayer/BriefingOverlay/BriefingCard/MarginContainer/VBox"]
layout_mode = 2
text = "But be careful. Each time you corner him he grows more dangerous — watch his mood. And he is still the master of this farm: open defiance, and the dogs will be the last thing you see."
autowrap_mode = 3
theme_override_font_sizes/font_size = 15
theme_override_colors/font_color = Color(0.165, 0.102, 0.031, 1)

[node name="Para4" type="Label" parent="UiLayer/BriefingOverlay/BriefingCard/MarginContainer/VBox"]
layout_mode = 2
text = "Expose as many lies as you can. Survive Napoleon."
autowrap_mode = 3
theme_override_font_sizes/font_size = 15
theme_override_colors/font_color = Color(0.165, 0.102, 0.031, 1)

[node name="Warning" type="Label" parent="UiLayer/BriefingOverlay/BriefingCard/MarginContainer/VBox"]
layout_mode = 2
text = "Warning: Once Napoleon turns wary or dangerous he does not soften — clean, well-evidenced questions are the safe play."
autowrap_mode = 3
theme_override_font_sizes/font_size = 13
theme_override_colors/font_color = Color(0.478, 0.102, 0.102, 1)

[node name="EnterBtn" type="Button" parent="UiLayer/BriefingOverlay/BriefingCard/MarginContainer/VBox"]
